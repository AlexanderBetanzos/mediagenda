# --- Secretos (NO subir credenciales) ---
# config/config.php SÍ se versiona (no contiene secretos).
config/secrets.php

# --- Herramientas locales ---
.claude/
.vscode/
.idea/

# --- Sistema operativo ---
.DS_Store
Thumbs.db

# --- Estado del deploy por FTP ---
.ftp-deploy-sync-state.json

# --- Logs / temporales ---
*.log
*.tmp

# --- Archivos subidos por usuarios (NO versionar el contenido) ---
uploads/expedientes/*
!uploads/expedientes/.gitkeep
uploads/pacientes/*
!uploads/pacientes/.gitkeep

# Logos subidos por cada consultorio (no versionar el contenido)
assets/logos/*
!assets/logos/.gitkeep
